<div id="DynamicGrid-{{ section.id }}" class="dynamic-grid section-{{ section.id }}-padding container">
  {%- if section.settings.heading != blank -%}
    <h2 class="section-heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="grid-container grid-{{ section.settings.columns_desktop }}-col">
    {%- for block in section.blocks -%}
      <div class="grid-item" {{ block.shopify_attributes }}>
        {%- case block.type -%}
          {%- when 'image_with_text' -%}
            <div class="card">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'card-image' }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
              <div class="card-content">
                <h3>{{ block.settings.title | escape }}</h3>
                <p>{{ block.settings.text }}</p>
              </div>
            </div>
          {%- when 'button' -%}
            <div class="button-wrapper">
              <a href="{{ block.settings.link }}" class="button primary-button">
                {{ block.settings.label | escape }}
              </a>
            </div>
        {%- endcase -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .grid-container {
    display: grid;
    gap: 20px;
  }
  @media screen and (min-width: 750px) {
    .grid-3-col { grid-template_columns: repeat(3, 1fr); }
    .grid-4-col { grid-template_columns: repeat(4, 1fr); }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Cuadrícula Dinámica",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título de la sección",
      "default": "Nuestros Destacados"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columnas en escritorio",
      "default": 3
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "image_with_text",
      "name": "Imagen con Texto",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Elemento de cuadrícula"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Descripción corta",
          "default": "Agrega un texto descriptivo aquí."
        }
      ]
    },
    {
      "type": "button",
      "name": "Botón de Acción",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta del botón",
          "default": "Ver detalles"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cuadrícula Dinámica",
      "blocks": [
        { "type": "image_with_text" },
        { "type": "image_with_text" },
        { "type": "image_with_text" }
      ]
    }
  ]
}
{% endschema %}
